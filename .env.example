# Spotify app Client ID (from https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
# Spotify app Client Secret (optional; PKCE flow works without it)
SPOTIFY_CLIENT_SECRET=
# OAuth redirect URI — must match a Redirect URI registered on the Spotify app exactly
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/auth/callback
# Long random string used to HMAC-sign session cookies (e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
SESSION_SECRET=
# Port the Hono server listens on (Vite proxies /auth, /api, /ws here in dev)
PORT=3000
# Node environment: development | production | test
NODE_ENV=development
# SQLite database path; in Docker point to the mounted volume (e.g. /data/bangerbingo.db)
DB_PATH=./bangerbingo.db
# Public domain name (e.g. bangerbingo.net or bingo.tail-xxx.ts.net) — used by Caddy in story 6-3
APP_DOMAIN=
# Comma-separated allowlist of WebSocket upgrade Origins (CSWSH guard). REQUIRED in production —
# if unset while NODE_ENV=production, all WS upgrades are rejected. In non-prod, defaults allow
# http(s)://localhost:*, http(s)://127.0.0.1:*, and http(s)://*.ts.net (tailnet).
# WS_ALLOWED_ORIGINS=https://bangerbingo.net
