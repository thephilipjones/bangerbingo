# Spotify app Client ID (from https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
# Spotify app Client Secret (optional; PKCE flow works without it)
SPOTIFY_CLIENT_SECRET=
# OAuth redirect URI — must match a Redirect URI registered on the Spotify app exactly
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/auth/callback
# Long random string used to HMAC-sign session cookies (e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
SESSION_SECRET=
# Port the Hono server listens on (Vite proxies /auth, /api, /ws here in dev)
PORT=3000
# Node environment: development | production | test
NODE_ENV=development
