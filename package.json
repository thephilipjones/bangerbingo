{
  "name": "bangerbingo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch --env-file=.env src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server && tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --format=esm --outfile=dist/server/index.js --packages=external",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.9.1",
    "hono": "^4.7.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@testing-library/svelte": "^5.3.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.17",
    "@types/spotify-web-playback-sdk": "^0.1.19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.2",
    "jsdom": "^29.0.1",
    "svelte": "^5.25.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.0.9"
  }
}
